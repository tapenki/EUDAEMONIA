# statuses

msgid "burn_title"
msgstr "[outline_color=#ff0000]Notes: Burn[/outline_color]"

msgid "burn_description"
msgstr "Deals [outline_size=10][STACKS][/outline_size] damage every second.[br]Expires after dealing damage [outline_size=10][5][/outline_size] times.[br]Reapplying burn resets expiration."

msgid "chill_title"
msgstr "[outline_color=#0000ff]Notes: Chill[/outline_color]"

msgid "chill_description"
msgstr "Reduces speed to [outline_size=10]x[0.5][/outline_size]."

msgid "freeze_title"
msgstr "[outline_color=#0000ff]Notes: Freeze[/outline_color]"

msgid "freeze_description"
msgstr "Reduces speed to [outline_size=10]x[0][/outline_size]."

msgid "shock_title"
msgstr "[outline_color=#a87e00]Notes: Shock[/outline_color]"

msgid "shock_description"
msgstr "[outline_size=10]+[STACKS]%[/outline_size] crit chance for incoming damage.[br]Lasts [outline_size=10][4][/outline_size] seconds."

msgid "doom_title"
msgstr "[outline_color=#cc00cc]Notes: Doom[/outline_color]"

msgid "doom_description"
msgstr "Accumulates up to [outline_size=10][10xSTACKS][/outline_size] damage and deals [outline_size=10][0.5xACCUMULATED][/outline_size] damage after [outline_size=10][4][/outline_size] seconds."

# fire
msgid "fire_title"
msgstr "[outline_color=#ff0000]Fire[/outline_color]"

msgid "fire_description"
msgstr "- The very hungry fire.[br]- Unexpired phenomena."

msgid "ignition_title"
msgstr "[outline_color=#ff0000]Ability: Ignition[/outline_color]"

msgid "ignition_description"
msgstr "[outline_size=10][33]% upon dealing damage:[/outline_size] Apply [outline_size=10][3xLEVEL][/outline_size] burn."

msgid "firespawning_title"
msgstr "[outline_color=#ff0000]Ability: Firespawning[/outline_color]"

msgid "firespawning_description"
msgstr "[outline_size=10]Upon encounter:[/outline_size] Summon [outline_size=10][4][/outline_size] flaming skulls. They have [outline_size=10][40xLEVEL][/outline_size] health, [outline_size=10]x[0.5xLEVEL][/outline_size] damage, and apply [outline_size=10][10xLEVEL][/outline_size] burn to nearby enemies when killed."

msgid "melt_title"
msgstr "[outline_color=#ff0000]Ability: Melt[/outline_color]"

msgid "melt_description"
msgstr "You have [outline_size=10]+[0.25xLEVELxSTACKS][/outline_size] damage against burning entities."

msgid "scorched_earth_title"
msgstr "[outline_color=#ff0000]Ability: Scorched Earth[/outline_color]"

msgid "scorched_earth_description"
msgstr "[outline_size=10][50]% upon a projectile expiring:[/outline_size] Manifest a pool of fire that deals [outline_size=10]x[0.25xLEVEL][/outline_size] damage."

msgid "from_ashes_title"
msgstr "[outline_color=#ff0000]Ability: From Ashes[/outline_color]"

msgid "from_ashes_description"
msgstr "[outline_size=10]Once per encounter, upon your imminent demise:[/outline_size] Escape your fate and recover [outline_size=10]+[10xLEVEL][/outline_size] health per second over [outline_size=10][5][/outline_size] seconds."

msgid "conflagration_title"
msgstr "[outline_color=#ff0000]Mastery: Conflagration[/outline_color]"

msgid "conflagration_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#ff0000]Ignition[/outline_color][br][outline_size=10]Upon a burning entity dying:[/outline_size] Spread its burn to the nearest enemy."

msgid "undying_flames_title"
msgstr "[outline_color=#ff0000]Mastery: Undying Flames[/outline_color]"

msgid "undying_flames_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#ff0000]Firespawning[/outline_color][br][outline_size=10]Upon a flaming skull dying:[/outline_size] Take [outline_size=10][LEVEL][/outline_size] pure damage and reconstitute it."

msgid "white_hot_title"
msgstr "[outline_color=#ff0000]Mastery: White Hot[/outline_color]"

msgid "white_hot_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#ff0000]Melt[/outline_color][br]You have [outline_size=10]+[100]%[/outline_size] crit chance against entities with [outline_size=10]>=[50][/outline_size] burn stacks."

msgid "ring_of_fire_title"
msgstr "[outline_color=#ff0000]Ability: Ring of Fire[/outline_color]"

msgid "ring_of_fire_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#ff0000]Scorched Earth[/outline_color][br][outline_size=10]Upon encounter:[/outline_size] Manifest a ring of fire around you. It has [outline_size=10]x[0.25xLEVEL][/outline_size] damage."

msgid "fiery_rebirth_title"
msgstr "[outline_color=#ff0000]Mastery: Fiery Rebirth[/outline_color]"

msgid "fiery_rebirth_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#ff0000]From Ashes[/outline_color][br][outline_size=10]Upon [/outline_size][outline_color=#ff0000]From Ashes[/outline_color][outline_size=10] activation:[/outline_size] Apply [outline_size=10]+[10xLEVEL][/outline_size] burn to all enemies then double their burn."

# ice
msgid "ice_title"
msgstr "[outline_color=#0000ff]Ice[/outline_color]"

msgid "ice_description"
msgstr "- Delay the inevitable.[br]- Allow enemies to break."

msgid "blue_needle_title"
msgstr "[outline_color=#0000ff]Ability: Blue Needle[/outline_color]"

msgid "blue_needle_description"
msgstr "Projectiles have [outline_size=10]+[LEVEL][/outline_size] pierce."

msgid "snowball_title"
msgstr "[outline_color=#0000ff]Ability: Snowball[/outline_color]"

msgid "snowball_description"
msgstr "Projectiles gain [outline_size=10]+[5xLEVEL][/outline_size] damage and [outline_size=10]x[1-0.5^LEVEL][/outline_size] bonus size per second."

msgid "frostbite_title"
msgstr "[outline_color=#0000ff]Ability: Frostbite[/outline_color]"

msgid "frostbite_description"
msgstr "[outline_size=10]Upon dealing damage:[/outline_size] Accumulate damage dealt.[br]Apply chill for [outline_size=10][LEVEL][/outline_size] seconds for every [outline_size=10][30%MAXHP][/outline_size] damage accumulated."

msgid "shatter_title"
msgstr "[outline_color=#0000ff]Ability: Shatter[/outline_color]"

msgid "shatter_description"
msgstr "[outline_size=10]Upon an entity dying:[/outline_size] It releases [outline_size=10][3][/outline_size] shards with [outline_size=10]+[5xLEVEL-5][/outline_size] damage. Summoned entities only release [outline_size=10][1][/outline_size] shards."

msgid "cryobombs_title"
msgstr "[outline_color=#0000ff]Ability: Cryobombs[/outline_color]"

msgid "cryobombs_description"
msgstr "[outline_size=10]Upon encounter:[/outline_size] Summon [outline_size=10][2][/outline_size] cryobombs. They accumulate up to [outline_size=10][60xLEVEL][/outline_size] damage taken, and explode dealing [outline_size=10]+[0.5xACCUMULATED][/outline_size] damage [outline_size=10][3][/outline_size] seconds after getting hit."

msgid "glacial_rail_title"
msgstr "[outline_color=#0000ff]Mastery: Glacial Rail[/outline_color]"

msgid "glacial_rail_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0000ff]Blue Needle[/outline_color][br]Projectiles have [outline_size=10]x[1.5][/outline_size] speed."

msgid "snowball_ii_title"
msgstr "[outline_color=#0000ff]Mastery: Snowball II[/outline_color]"

msgid "snowball_ii_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0000ff]Snowball[/outline_color][br]Projectiles gain [outline_size=10]+[5xLEVEL]%[/outline_size] crit chance per second."

msgid "snap_freeze_title"
msgstr "[outline_color=#0000ff]Mastery: Snap Freeze[/outline_color]"

msgid "snap_freeze_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0000ff]Frostbite[/outline_color][br][outline_size=10]Upon dealing damage:[/outline_size] Accumulate damage dealt.[br]Apply freeze for [outline_size=10][0.5xLEVEL][/outline_size] seconds for every [outline_size=10][60%MAXHP][/outline_size] damage accumulated."

msgid "brittle_cold_title"
msgstr "[outline_color=#0000ff]Mastery: Brittle Cold[/outline_color]"

msgid "brittle_cold_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0000ff]Shatter[/outline_color][br]You have [outline_size=10]+[100]%[/outline_size] crit chance against entities with [outline_size=10]<=[33%MAXHP][/outline_size] health."

msgid "freeze_blast_title"
msgstr "[outline_color=#0000ff]Mastery: Freeze Blast[/outline_color]"

msgid "freeze_blast_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0000ff]Cryobombs[/outline_color][br]Cryobombs apply freeze for [outline_size=10][1.5][/outline_size] seconds upon dealing damage."

# lightning
msgid "lightning_title"
msgstr "[outline_color=#a87e00]Lightning[/outline_color]"

msgid "lightning_description"
msgstr "- Unexplained phenomena.[br]- Lightning tastes better than key."

msgid "chain_bolt_title"
msgstr "[outline_color=#a87e00]Ability: Chain Bolt[/outline_color]"

msgid "chain_bolt_description"
msgstr "You have [outline_size=10]+[5xLEVEL]%[/outline_size] crit chance.[br][outline_size=10]Upon crit:[/outline_size] Damage chains to the closest enemy up to [outline_size=10][LEVEL][/outline_size] times."

msgid "mortal_shock_title"
msgstr "[outline_color=#a87e00]Ability: Mortal Shock[/outline_color]"

msgid "mortal_shock_description"
msgstr "You have [outline_size=10]+[20xLEVEL]%[/outline_size] crit chance against undamaged enemies and [outline_size=10]+[3xLEVEL][/outline_size] damage on crit."

msgid "ball_lightning_title"
msgstr "[outline_color=#a87e00]Ability: Ball Lightning[/outline_color]"

msgid "ball_lightning_description"
msgstr "You manifest [outline_size=10][2][/outline_size] ball lightnings orbiting around you. They have [outline_size=10]+[5xLEVEL-5][/outline_size] damage and [outline_size=10]x[2]%[/outline_size] crit chance."

msgid "electromagnetism_title"
msgstr "[outline_color=#a87e00]Ability: Electromagnetism[/outline_color]"

msgid "electromagnetism_description"
msgstr "Projectiles home into enemies within [outline_size=10][50+50xLEVEL]px[/outline_size]."

msgid "thunderstep_title"
msgstr "[outline_color=#a87e00]Ability: Thunderstep[/outline_color]"

msgid "thunderstep_description"
msgstr "You have [outline_size=10]+[40xLEVEL][/outline_size] move speed and [outline_size=10]+[0.25xLEVEL][/outline_size] seconds of immunity when hit."

msgid "storm_weave_title"
msgstr "[outline_color=#a87e00]Mastery: Storm Weave[/outline_color]"

msgid "storm_weave_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#a87e00]Chain Bolt[/outline_color][br][outline_size=10]When dealing damage:[/outline_size] roll for crits an additional time with [outline_size=10]x[0.1][/outline_size] crit chance."

msgid "shocking_grasp_title"
msgstr "[outline_color=#a87e00]Mastery: Shocking Grasp[/outline_color]"

msgid "shocking_grasp_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#a87e00]Mortal Shock[/outline_color][br][outline_size=10]Upon dealing damage to an undamaged entity:[/outline_size] Apply [outline_size=10][10xLEVEL][/outline_size] shock."

msgid "covalence_title"
msgstr "[outline_color=#a87e00]Mastery: Covalence[/outline_color]"

msgid "covalence_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#a87e00]Ball Lightning[/outline_color][br]Manifest [outline_size=10]+[1][/outline_size]Ball lightning.[br]Ball lightnings have [outline_size=10]x[0.6][/outline_size] orbit distance."

msgid "repulsar_title"
msgstr "[outline_color=#a87e00]Mastery: Repulsar[/outline_color]"

msgid "repulsar_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#a87e00]Electromagnetism[/outline_color][br]You divert nearby enemy projectiles."

msgid "arc_shield_title"
msgstr "[outline_color=#a87e00]Mastery: Arc Shield[/outline_color]"

msgid "arc_shield_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#a87e00]Thunderstep[/outline_color][br]You have [outline_size=10][20]%[/outline_size] chance to take [outline_size=10]x[0][/outline_size]."

msgid "crit_title"
msgstr "[outline_color=#a87e00]Notes: Crit[/outline_color]"

msgid "crit_description"
msgstr "[outline_size=10]When dealing damage:[/outline_size] roll for crits.[br]Gain [outline_size=10]x[2][/outline_size] damage and [outline_size=10]x[1.5][/outline_size] damage accumulated on crit."

# life
msgid "life_title"
msgstr "[outline_color=#0f9936]Life[/outline_color]"

msgid "life_description"
msgstr "- Smile through the pain.[br]- As the years go by life will never die."

msgid "enrage_title"
msgstr "[outline_color=#0f9936]Ability: Enrage[/outline_color]"

msgid "enrage_description"
msgstr "[outline_size=10]Upon taking damage:[/outline_size] You and your allies gain [outline_size=10]+[0.05xDMGTAKEN][/outline_size] damage until the end of encounter up to [outline_size=10]+[5xLEVEL][/outline_size]."

msgid "wrought_flesh_title"
msgstr "[outline_color=#0f9936]Ability: Wrought Flesh[/outline_color]"

msgid "wrought_flesh_description"
msgstr "You have [outline_size=10]+[25xLEVEL][/outline_size] max health and recover [outline_size=10]+[LEVEL][/outline_size] health per second."

msgid "trail_of_thorns_title"
msgstr "[outline_color=#0f9936]Ability: Trail of Thorns[/outline_color]"

msgid "trail_of_thorns_description"
msgstr "[outline_size=10]Every [75]px you move:[/outline_size] Manifest a thorn.[br]It has [outline_size=10]+[3xLEVEL-3][/outline_size] damage and [outline_size=10]+[LEVEL-1][/outline_size] pierce."

msgid "quill_spray_title"
msgstr "[outline_color=#0f9936]Ability: Quill Spray[/outline_color]"

msgid "quill_spray_description"
msgstr "[outline_size=10]Upon taking damage:[/outline_size] Release a spray of quills.[br]They have [outline_size=10]x[2][/outline_size] damage and [outline_size=10]+[0.6+0.4xLEVEL][/outline_size] size."

msgid "animated_clay_title"
msgstr "[outline_color=#0f9936]Ability: Animated Clay[/outline_color]"

msgid "animated_clay_description"
msgstr "[outline_size=10]Upon encounter:[/outline_size] Summon a clay effigy. It has [outline_size=10]+[80xLEVEL][/outline_size] health and your personal abilities."

msgid "bramble_shot_title"
msgstr "[outline_color=#0f9936]Ability: Bramble Shot[/outline_color]"

msgid "bramble_shot_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0f9936]Enrage[/outline_color][br][outline_size=10]Upon pressing {keybind}:[/outline_size] You take [outline_size=10][25][/outline_size] pure damage and shoot a bramble with [outline_size=10]x[3][/outline_size] damage."

msgid "pain_walk_title"
msgstr "[outline_color=#0f9936]Mastery: Pain Walk[/outline_color]"

msgid "pain_walk_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0f9936]Trail of Thorns[/outline_color][br][outline_size=10]Every [75]px you move:[/outline_size] Manifest [outline_size=10]+[1][/outline_size] thorn. [outline_size=10]Every other activation:[/outline_size] Take [outline_size=10][3][/outline_size] pure damage."

msgid "vitalism_title"
msgstr "[outline_color=#0f9936]Mastery: Vitalism[/outline_color]"

msgid "vitalism_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0f9936]Wrought Flesh[/outline_color][br]You have [outline_size=10]x[2][/outline_size] health recovery."

msgid "pressurized_quills_title"
msgstr "[outline_color=#0f9936]Mastery: Pressurized Quills[/outline_color]"

msgid "pressurized_quills_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0f9936]Quill Spray[/outline_color][br][outline_color=#0f9936]Quill Spray[/outline_color] gains [outline_size=10]x[0.2][/outline_size] bonus damage and size per second for up to [outline_size=10][5][/outline_size] seconds resetting upon activation."

msgid "multimold_title"
msgstr "[outline_color=#0f9936]Mastery: Multimold[/outline_color]"

msgid "multimold_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#0f9936]Animated Clay[/outline_color][br][outline_size=10]Upon encounter:[/outline_size] Summon [outline_size=10]+[1][/outline_size] clay effigy. Clay effigies have [outline_size=10]x[0.5][/outline_size] health."

# death
msgid "death_title"
msgstr "[outline_color=#cc00cc]Death[/outline_color]"

msgid "death_description"
msgstr "- It's time to die your life.[br]- It's time for life to die."

msgid "army_of_the_dead_title"
msgstr "[outline_color=#cc00cc]Ability: Army of the Dead[/outline_color]"

msgid "army_of_the_dead_description"
msgstr "[outline_size=10]Upon slaying a non summoned enemy:[/outline_size] reconstitute it as an ally with [outline_size=10][BASEHPx0.5xLEVEL][/outline_size] health and [outline_size=10]+[3xLEVEL-3][/outline_size] damage."

msgid "fated_end_title"
msgstr "[outline_color=#cc00cc]Ability: Fated End[/outline_color]"

msgid "fated_end_description"
msgstr "[outline_size=10]Upon dealing damage to an undamaged entity:[/outline_size] Apply [outline_size=10][4xLEVEL][/outline_size] doom."

msgid "hunger_title"
msgstr "[outline_color=#cc00cc]Ability: Hunger[/outline_color]"

msgid "hunger_description"
msgstr "Summoned allies have [outline_size=10]+[20xLEVEL][/outline_size] max health.[br][outline_size=10]Upon an entity dying:[/outline_size] Summoned allies recover [outline_size=10]+[20xLEVEL][/outline_size] health."

msgid "bone_shield_title"
msgstr "[outline_color=#cc00cc]Ability: Bone Shield[/outline_color]"

msgid "bone_shield_description"
msgstr "[outline_size=10]Upon encounter:[/outline_size] Summon a bone shield. It has [outline_size=10]+[60xLEVEL][/outline_size] health and applies chill for [outline_size=10][0.3][/outline_size] seconds upon dealing damage."

msgid "dark_harvest_title"
msgstr "[outline_color=#cc00cc]Ability: Dark Harvest[/outline_color]"

msgid "dark_harvest_description"
msgstr "[outline_size=10]Upon pressing {keybind}:[/outline_size] A summoned ally explodes. The explosion has [outline_size=10]x[2][/outline_size] of its damage and [outline_size=10]+[0.6+0.4xLEVEL][/outline_size] size."

msgid "soul_tether_title"
msgstr "[outline_color=#cc00cc]Mastery: Soul Tether[/outline_color]"

msgid "soul_tether_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#cc00cc]Army of the Dead[/outline_color][br][outline_size=10]Upon encounter:[/outline_size] Last elite entity reconstituted by [outline_color=#cc00cc]Army of the Dead[/outline_color] is reconstituted once more."

msgid "swift_fate_title"
msgstr "[outline_color=#cc00cc]Mastery: Swift Fate[/outline_color]"

msgid "swift_fate_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#cc00cc]Fated End[/outline_color][br]Doom you apply has [outline_size=10]x[0.5][/outline_size] duration and [outline_size=10]x[1.5][/outline_size] damage."

msgid "starvation_title"
msgstr "[outline_color=#cc00cc]Mastery: Starvation[/outline_color]"

msgid "starvation_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#cc00cc]Hunger[/outline_color][br][outline_size=10]Upon an entity dying:[/outline_size] Summoned allies gain [outline_size=10]+[0.4xLEVEL][/outline_size] bonus damage."

msgid "osteophalanx_title"
msgstr "[outline_color=#cc00cc]Mastery: Osteophalanx[/outline_color]"

msgid "osteophalanx_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#cc00cc]Bone Shield[/outline_color][br][outline_size=10]Upon encounter:[/outline_size] Summon [outline_size=10]+[3][/outline_size] bone shields."

msgid "bad_crop_title"
msgstr "[outline_color=#cc00cc]Mastery: Bad Crop[/outline_color]"

msgid "bad_crop_description"
msgstr "[outline_size=10]Requires:[/outline_size] Level [outline_size=10][5][/outline_size] [outline_color=#cc00cc]Dark Harvest[/outline_color][br][outline_color=#cc00cc]Dark Harvest[/outline_color] explosion applies [outline_size=10][0.05xALLYMAXHP][/outline_size] doom."

